# Example environment for the donation bot. Copy to `.env` and fill in real
# values. NEVER commit a real `.env`. See docs/CONFIGURATION.md for the full,
# authoritative reference.

# --- Application ---
APP_ENV=production
LOG_LEVEL=INFO
DEFAULT_LOCALE=uz
ORG_TIMEZONE=Asia/Tashkent

# --- Telegram ---
BOT_TOKEN=CHANGE_ME
BOT_MODE=polling
# Required only when BOT_MODE=webhook:
WEBHOOK_BASE_URL=
WEBHOOK_SECRET=
WEBHOOK_PORT=8080

# --- Database ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=donation_bot
APP_DB_USER=donation_app
APP_DB_PASSWORD=CHANGE_ME
MIGRATION_DB_USER=donation_migrator
MIGRATION_DB_PASSWORD=CHANGE_ME

# --- Bootstrap ---
FIRST_SUPER_ADMIN_TELEGRAM_ID=000000000
FIRST_SUPER_ADMIN_NAME=Bosh admin

# --- Backups ---
BACKUP_DIR=/data/backups
BACKUP_SCHEDULE_CRON=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_KEY=CHANGE_ME          # store OFF the VPS, separate from backups
BACKUP_OFFSITE_TARGET=                   # e.g. s3://bucket/path or remote host

# Receipts / STORAGE_* / S3_* : Version 2 only — not used in v1
# Provider keys (CLICK_*, PAYME_*, ...) : post-v1 — not used in v1
